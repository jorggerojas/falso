{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"vcs": {
		"enabled": false,
		"clientKind": "git",
		"useIgnoreFile": true,
		"defaultBranch": "develop",
		"root": "./"
	},
	"files": {
		"ignoreUnknown": true,
		"includes": [
			"**",
			"!**/dist",
			"!**/coverage",
			"!**/node_modules",
			"!**/.firebase",
			"!./.firebase",
			"!.firebase",
			"!**/public",
			"!dist",
			"!./dist",
			"!**/*.{css}",
			"!**/*.d.ts",
			"!bun.lockb",
			"!biome.json",
			"!.agents/skills",
			"!.vercel"
		]
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"assist": {
		"enabled": false
	},
	"html": {
		"experimentalFullSupportEnabled": true
	},
	"overrides": [
		{
			"includes": ["**/*.astro"],
			"linter": {
				"rules": {
					"correctness": {
						"useJsxKeyInIterable": "off"
					}
				}
			}
		},
		{
			"includes": [".firebase/**", "firebase.json"],
			"linter": {
				"rules": {
					"style": {
						"useConst": "off",
						"useImportType": "off"
					},
					"correctness": {
						"noUnusedVariables": "off",
						"noUnusedImports": "off"
					}
				}
			}
		}
	]
}
